# =============================================================================
# Live Detection System — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --------------- Application ---------------
APP_NAME="Live Detection System"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# --------------- Server ---------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=1

# --------------- Database ---------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/live_detection

# --------------- Redis ---------------
REDIS_URL=redis://localhost:6379/0

# --------------- Model Configuration ---------------
MODEL_DEVICE=cpu
# Use "cuda:0" for GPU inference, "cpu" for CPU-only

YOLO_MODEL_PATH=models/weights/yolo11s.pt
MASK_MODEL_PATH=models/weights/yolo11n_mask.pt
EMOTION_MODEL_NAME=enet_b0_8_va_mtl

INFERENCE_CONFIDENCE_THRESHOLD=0.5
TRACKER_TYPE=bytetrack

# --------------- Alert — Email ---------------
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USERNAME=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# --------------- Alert — Telegram ---------------
ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# --------------- CORS ---------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --------------- API Security ---------------
API_KEY=

# --------------- Storage ---------------
SNAPSHOT_DIR=data/snapshots
VIDEO_CLIP_DIR=data/clips

# --------------- Monitoring ---------------
PROMETHEUS_ENABLED=true
